{
	"name": "micromanus",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/dm-sans": "^5.3.0",
		"@fontsource-variable/inter": "^5.3.0",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.25.0",
		"@playwright/test": "^1.61.1",
		"@sveltejs/kit": "^2.70.1",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.3",
		"@types/bun": "^1.3.14",
		"@types/node": "^24.13.3",
		"@vitest/browser-playwright": "^4.1.10",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.21.0",
		"globals": "^17.7.0",
		"mode-watcher": "^1.1.0",
		"motion-sv": "^0.1.13",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.1",
		"playwright": "^1.61.1",
		"shadcn-svelte": "^1.4.2",
		"svelte": "^5.56.6",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.7.3",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.3",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.64.0",
		"vite": "^8.1.5",
		"vitest": "^4.1.10",
		"vitest-browser-svelte": "^2.2.1",
		"zod": "^4.4.3"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^4.0.16",
		"@ai-sdk/openai": "^4.0.16",
		"@ai-sdk/svelte": "^5.0.31",
		"@polar-sh/better-auth": "^1.8.4",
		"@polar-sh/sdk": "^0.48.1",
		"ai": "^7.0.31",
		"better-auth": "~1.4.22",
		"drizzle-orm": "^0.45.2",
		"jspdf": "^4.2.1",
		"marked": "^18.0.6",
		"postgres": "^3.4.9",
		"runed": "^0.37.1",
		"svelte-streamdown": "^3.1.2"
	}
}
